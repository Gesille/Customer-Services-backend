<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CV Received</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f5f7; font-family: Arial, Helvetica, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f5f7; padding: 40px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius: 8px; overflow:hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">

          <!-- Header -->
          <tr>
            <td style="background-color:#1a1a2e; padding: 32px 40px;" align="center">
              <img src="https://res.cloudinary.com/dbjwhpzil/image/upload/v1783628117/NextID-Logo-CMYK_1_nsvnib.png" alt="Your Company" width="140" style="display:block;" />
            </td>
          </tr>

          <!-- Success Icon / Banner -->
          <tr>
            <td style="padding: 40px 40px 0 40px;" align="center">
              <div style="width:64px; height:64px; background-color:#e8f5e9; border-radius:50%; display:inline-block; line-height:64px; font-size:28px; color:#2e7d32;">
                &#10003;
              </div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 24px 40px 8px 40px;" align="center">
              <h1 style="margin:0; font-size:22px; color:#1a1a2e; font-weight:600;">CV Received Successfully</h1>
            </td>
          </tr>

          <tr>
            <td style="padding: 16px 40px 0 40px; color:#4a4a58; font-size:15px; line-height:1.6;">
              <p style="margin:0 0 16px 0;">Hi <strong><%= name %></strong>,</p>
              <p style="margin:0 0 16px 0;">
                Thank you for submitting your CV to us. We've received your information and our HR team
                will carefully review it. If your profile matches a current or upcoming opportunity,
                we'll be in touch directly.
              </p>
              <p style="margin:0 0 16px 0;">
                In the meantime, feel free to keep an eye on our careers page for new openings.
              </p>
            </td>
          </tr>

          <!-- CTA Button -->
          <tr>
            <td style="padding: 8px 40px 32px 40px;" align="center">
              <a href="https://yourcompany.com/careers"
                 style="background-color:#1a1a2e; color:#ffffff; text-decoration:none; padding: 12px 28px; border-radius: 6px; font-size:14px; font-weight:600; display:inline-block;">
                View Open Positions
              </a>
            </td>
          </tr>

          <tr>
            <td style="padding: 0 40px 32px 40px; border-top: 1px solid #eeeeee;">
              <p style="margin:24px 0 0 0; color:#8a8a94; font-size:13px; line-height:1.6;">
                This is an automated confirmation — no action is needed from you right now.
                If you didn't submit this CV, please disregard this email.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#fafafa; padding: 24px 40px; text-align:center;">
              <p style="margin:0; color:#a0a0a8; font-size:12px;">
                &copy; <%= new Date().getFullYear() %> Your Company Name. All rights reserved.
              </p>
              <p style="margin:8px 0 0 0; color:#a0a0a8; font-size:12px;">
                123 Business Street, City, Country
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>