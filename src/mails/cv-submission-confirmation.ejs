<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CV Received</title>
</head>
<body style="margin:0; padding:0; background-color:#0B0E14; font-family: Arial, Helvetica, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#0B0E14; padding: 48px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#111623; border:1px solid #1F2637; border-radius: 12px; overflow:hidden;">

          <!-- Header / logo -->
          <tr>
            <td style="padding: 32px 40px; border-bottom:1px solid #1F2637;" align="center">
              <img src="https://res.cloudinary.com/dbjwhpzil/image/upload/v1783628117/NextID-Logo-CMYK_1_nsvnib.png" alt="Company" width="130" style="display:block;" />
            </td>
          </tr>

          <!-- Success icon -->
          <tr>
            <td style="padding: 40px 40px 0 40px;" align="center">
              <div style="width:60px; height:60px; background-color:rgba(212,175,55,0.12); border:1px solid rgba(212,175,55,0.3); border-radius:50%; display:inline-block; line-height:60px; font-size:24px; color:#D4AF37;">
                &#10003;
              </div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 24px 40px 0 40px;" align="center">
              <h1 style="margin:0; font-size:22px; color:#F5F5F0; font-weight:700;">New CV Submitted</h1>
            </td>
          </tr>

          <tr>
            <td style="padding: 16px 44px 0 44px; color:#9AA1B1; font-size:14px; line-height:1.7; text-align:center;">
              <p style="margin:0 0 16px 0;">Hi <strong style="color:#F5F5F0;"><%= name %></strong>,</p>
              <p style="margin:0 0 16px 0;">
                Thank you for submitting your CV. Our team will carefully review your information,
                and if your profile matches a current or upcoming opportunity, we'll reach out directly.
              </p>
              <p style="margin:0;">
                In the meantime, feel free to check our careers page for new openings.
              </p>
            </td>
          </tr>

          <!-- CTA Button -->
          <tr>
            <td style="padding: 28px 40px 36px 40px;" align="center">
              <a href="https://yourcompany.com/careers"
                 style="background-color:#D4AF37; color:#0B0E14; text-decoration:none; padding: 13px 30px; border-radius: 8px; font-size:14px; font-weight:700; display:inline-block;">
                View Open Positions
              </a>
            </td>
          </tr>

          <tr>
            <td style="padding: 0 40px 32px 40px; border-top: 1px solid #1F2637;">
              <p style="margin:20px 0 0 0; color:#5B6478; font-size:12px; line-height:1.6; text-align:center;">
                This is an automated confirmation — no action is needed from you right now.
                If you didn't submit this application, you can disregard this email.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#0B0E14; padding: 22px 40px; text-align:center; border-top:1px solid #1F2637;">
              <p style="margin:0; color:#5B6478; font-size:12px;">
                &copy; <%= new Date().getFullYear() %> Your Company Name. All rights reserved.
              </p>
              <p style="margin:6px 0 0 0; color:#3E4658; font-size:12px;">
                123 Business Street, City, Country
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
