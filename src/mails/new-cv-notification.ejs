<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New CV Submission</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f5f7; font-family: Arial, Helvetica, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f5f7; padding: 40px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius: 8px; overflow:hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">

          <!-- Header -->
          <tr>
            <td style="background-color:#0f4c81; padding: 28px 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="color:#ffffff; font-size:18px; font-weight:700;">
                    New CV Submission
                  </td>
                  <td align="right">
                    <span style="background-color:#ffffff; color:#0f4c81; font-size:12px; font-weight:700; padding:6px 12px; border-radius: 20px;">
                      GENERAL APPLICATION
                    </span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Intro -->
          <tr>
            <td style="padding: 28px 40px 0 40px; color:#4a4a58; font-size:15px; line-height:1.6;">
              <p style="margin:0;">A new candidate has submitted a CV through the website. Details below:</p>
            </td>
          </tr>

          <!-- Details Card -->
          <tr>
            <td style="padding: 20px 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f8f9fb; border:1px solid #edeef1; border-radius: 8px;">
                <tr>
                  <td style="padding: 16px 20px; border-bottom:1px solid #edeef1; width:35%; color:#8a8a94; font-size:13px; font-weight:600;">NAME</td>
                  <td style="padding: 16px 20px; border-bottom:1px solid #edeef1; color:#1a1a2e; font-size:14px;"><%= name %></td>
                </tr>
                <tr>
                  <td style="padding: 16px 20px; border-bottom:1px solid #edeef1; color:#8a8a94; font-size:13px; font-weight:600;">EMAIL</td>
                  <td style="padding: 16px 20px; border-bottom:1px solid #edeef1; color:#1a1a2e; font-size:14px;">
                    <a href="mailto:<%= email %>" style="color:#0f4c81; text-decoration:none;"><%= email %></a>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 16px 20px; border-bottom:1px solid #edeef1; color:#8a8a94; font-size:13px; font-weight:600;">PHONE</td>
                  <td style="padding: 16px 20px; border-bottom:1px solid #edeef1; color:#1a1a2e; font-size:14px;"><%= phone %></td>
                </tr>
                <tr>
                  <td style="padding: 16px 20px; border-bottom:1px solid #edeef1; color:#8a8a94; font-size:13px; font-weight:600;">LINKEDIN</td>
                  <td style="padding: 16px 20px; border-bottom:1px solid #edeef1; color:#1a1a2e; font-size:14px;">
                    <% if (linkedin && linkedin !== "Not provided") { %>
                      <a href="<%= linkedin %>" style="color:#0f4c81; text-decoration:none;"><%= linkedin %></a>
                    <% } else { %>
                      Not provided
                    <% } %>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 16px 20px; color:#8a8a94; font-size:13px; font-weight:600; vertical-align:top;">MESSAGE</td>
                  <td style="padding: 16px 20px; color:#1a1a2e; font-size:14px; line-height:1.5;"><%= message %></td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- CTA Button -->
          <tr>
            <td style="padding: 8px 40px 32px 40px;" align="center">
              <a href="<%= adminUrl %>"
                 style="background-color:#0f4c81; color:#ffffff; text-decoration:none; padding: 12px 28px; border-radius: 6px; font-size:14px; font-weight:600; display:inline-block;">
                View in Admin Dashboard
              </a>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#fafafa; padding: 20px 40px; text-align:center; border-top:1px solid #eeeeee;">
              <p style="margin:0; color:#a0a0a8; font-size:12px;">
                Automated notification from Your Company Name recruitment system.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>